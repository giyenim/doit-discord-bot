# --- 봇 기본 ---
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# --- /인증 ---
# ADMIN_CHANNEL_ID: 인증 요청 버튼이 게시될 관리자 채널
# VERIFY_CHANNEL_ID: /인증 명령어가 허용되는 공개 채널
ADMIN_CHANNEL_ID=admin_channel_id_here
VERIFY_CHANNEL_ID=verify_channel_id_here

# --- 스터디 역할 (인증 승인 시 부여 / 미션현황의 전체 인원 집합으로도 사용) ---
# ※ /미션현황이 ROLE_ID_OPTION_1/2 보유자 전원을 "이번 주 대상자"로 잡습니다.
#    이 때문에 Discord Developer Portal → Bot → "Server Members Intent" 토글이 켜져 있어야 합니다.
ROLE_ID_OPTION_1=role_id_for_option_1
ROLE_LABEL_OPTION_1=옵션1
ROLE_ID_OPTION_2=role_id_for_option_2
ROLE_LABEL_OPTION_2=옵션2

# --- /진도 (cron 자동 알림 + 사용자 조회 + /미션현황 채널 정책) ---
# PROGRESS_CHANNEL_ID_OPTION_1/2: 진도 알림이 게시되는 채널.
#   /진도, /미션현황 모두 이 채널에서만 실행 허용.
# PROGRESS_CRON_OPTION_1/2: 진도 자동 알림 cron (Asia/Seoul).
PROGRESS_CHANNEL_ID_OPTION_1=progress_channel_id_for_option_1
PROGRESS_CRON_OPTION_1=0 9 * * 1-5
PROGRESS_CHANNEL_ID_OPTION_2=progress_channel_id_for_option_2
PROGRESS_CRON_OPTION_2=0 21 * * 1-5
